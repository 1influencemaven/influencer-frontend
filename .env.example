# Backend API base URL (includes global prefix and version)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Frontend origin in development (must match `npm run dev` port)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Backend origin used by Next.js rewrites when NEXT_PUBLIC_API_URL is relative
# Dev: http://localhost:3000
# Docker prod build: http://influencer-backend:3000
API_ORIGIN=http://localhost:3000
